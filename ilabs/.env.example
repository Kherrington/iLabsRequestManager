# iLab API configuration
# Copy this file to .env and fill in your token.
# Load it before running scripts:
#   Windows PowerShell : $env:ILAB_TOKEN = "your_token_here"
#   Bash/macOS/Linux   : export ILAB_TOKEN="your_token_here"
# Or install python-dotenv and it will be loaded automatically if you add
# `from dotenv import load_dotenv; load_dotenv()` at the top of your script.

# Bearer token from iLab Administration > API Clients
ILAB_TOKEN=your_token_here

# Base URL — only change this if you are using a different iLab instance
# ILAB_BASE_URL=https://ucsf.ilab.agilent.com
